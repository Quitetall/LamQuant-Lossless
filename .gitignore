# LamQuant Gen 6 Git Bounds

# Python Artifacts
__pycache__/
*.py[cod]
*$py.class
*.env
.venv/
env/
venv/

# AI Dataset / Model Weights
ai_models/dataset_sim/dataset/
ai_models/dataset_sim/q31_events/*.npz
*.ckpt
*.pt
*.pth

# Exception: weights/ directory is tracked (ships to end users)
!weights/*.ckpt
!weights/*.pt
!weights/*.pth

# Generated Firmware Exports
firmware/firmware_export/*.h
firmware/firmware_export/*.bin

# Build Dependencies
build/
firmware/build/
*.o
*.elf
*.uf2
*.map

# Training logs (generated artifacts, not source)
*.log

# Test Harness Logs

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Python packaging artifacts (created by pip install -e .)
*.egg-info/
*.egg
dist/

# GUI build artifacts
gui/node_modules/
gui/.svelte-kit/
gui/build/
gui/src-tauri/target/
gui/src-tauri/gen/

# IDEs
.vscode/
.idea/
*.swp
.DS_Store
*.edf
ai_models/dataset_sim/datasets/
.training_queue.json
.training_state.json
training_logs/

# External pretrained models / vendored reference code — pulled on demand.
# `dependencies/README.md` documents how to fetch each (HF / git clone).
# Subdir wildcard ignores every vendored teacher checkpoint while
# keeping the README + small text indices tracked.
dependencies/*/
!dependencies/README.md

# SNN training labels (generated by ai_models/snn/generate_activity_labels.py)
ai_models/snn/labels/*.npz
ai_models/snn/labels_chbmit/

# Teacher memmap cache (generated data)
ai_models/dataset_sim/teacher_memmap/

# Fullband target memmaps (regenerable via precompute_fullband_memmap.py;
# 136 GB train + 10 GB val — never commit). The .meta.json sidecars
# embed machine-specific NPZ paths, so ignore those too.
ai_models/dataset_sim/fullband_*.dat
ai_models/dataset_sim/fullband_*.meta.json

# Training logs and output artifacts (training_logs/ is duplicated from
# the IDE block above; left intentional so the rule is visible alongside
# outputs/ — both are derived).
outputs/
*.egg-info/
annotation_index.json
annotation_index_unannotated.txt

# Build artifacts
target/
.numba_cache/
*.elf
*.map

# User-local config — copy lamquant.toml.example to lamquant.toml to start.
# The .example file is tracked; the active config is per-user and gitignored.
lamquant.toml

# Vendored SDKs
sdk/

# Case-corrected
reference_software/

# Local data sync scripts (contain server credentials/paths)
scripts/sync_tuh_all.sh
scripts/sync_tuh_annotations.sh
scripts/update_tueg_super.sh

# graphify-out — knowledge-graph tool outputs.
# All artifacts (graph.json ~190MB, graph.html, GRAPH_REPORT.md,
# cost.json, manifest.json, .graphify_*) are regenerable via
# `graphify update .` (AST-only, no API cost). Removed from index
# 2026-05-21 — keeping them tracked carried 86% of repo size in
# regenerable output. AI models pull fresh via the graphify CLI.
graphify-out/

# external/ — third-party reference repos cloned on demand for
# benching (currently Wren6991/Hazard3 RTL for the RP2350 silicon
# bench harness in tools/hazard3_bench). Each subdir is pulled by
# the runbook in tools/bench_rp2350_silicon.md.
external/
