# LamQuant Gen 6 Git Bounds

# Python Artifacts
__pycache__/
*.py[cod]
*$py.class
*.env
.venv/
env/
venv/

# AI Dataset / Model Weights
ai_models/dataset_sim/dataset/
ai_models/dataset_sim/q31_events/*.npz
*.ckpt
*.pt
*.pth

# Exception: weights/ directory is tracked (ships to end users)
!weights/*.ckpt
!weights/*.pt
!weights/*.pth

# Generated Firmware Exports
firmware/firmware_export/*.h
firmware/firmware_export/*.bin

# Build Dependencies
build/
firmware/build/
*.o
*.elf
*.uf2
*.map

# Training logs (generated artifacts, not source)
*.log

# Test Harness Logs
testing/*.json

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Python packaging artifacts (created by pip install -e .)
*.egg-info/
*.egg
dist/

# GUI build artifacts
gui/node_modules/
gui/.svelte-kit/
gui/build/
gui/src-tauri/target/
gui/src-tauri/gen/

# IDEs
.vscode/
.idea/
*.swp
.DS_Store
*.edf
ai_models/dataset_sim/datasets/
.training_queue.json
.training_state.json
training_logs/

# External pretrained models / vendored reference code — pulled on demand.
# `dependencies/README.md` documents how to fetch each (HF / git clone).
dependencies/labram/
dependencies/zuna/
Reference Software/

# SNN training labels (generated by ai_models/snn/generate_activity_labels.py)
ai_models/snn/labels/*.npz
ai_models/snn/labels_chbmit/

# Teacher memmap cache (generated data)
ai_models/dataset_sim/teacher_memmap/

# Training logs and output artifacts
training_logs/
outputs/
